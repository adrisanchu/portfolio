---
interface Props {
	slug: string;
	title: string;
	summary: string;
	stack: string[];
	year: number;
	featured?: boolean;
	confidential?: boolean;
}

const { slug, title, summary, stack, year, featured = false, confidential = true } = Astro.props;
const  MAX_STACK = 4;
---

<a href={`/projects/${slug}`} class:list={['project-card', { featured }]}>
	<div class="card-top">
		<span class="card-year">{year}</span>
		{confidential && (
			<svg class="lock-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-label="Confidential project">
				<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
				<path d="M7 11V7a5 5 0 0 1 10 0v4"/>
			</svg>
		)}
	</div>
	<h3 class="card-title">{title}</h3>
	<p class="card-summary">{summary}</p>
	<div class="card-stack">
		{stack.length <= MAX_STACK
			? stack.map((tech) => <span class="stack-chip">{tech}</span>)
			: stack.slice(0, MAX_STACK).map((tech) => <span class="stack-chip">{tech}</span>)
		}
		{stack.length > MAX_STACK && <span class="stack-chip muted">+{stack.length - MAX_STACK}</span>}
	</div>
	<span class="card-arrow">View case study →</span>
</a>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 1.5rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		text-decoration: none;
		transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
		color: inherit;
		box-shadow: var(--card-shadow);
	}

	.project-card:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		box-shadow: var(--card-shadow);
	}

	.card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.card-year {
		font-size: 0.75rem;
		color: var(--fg-muted);
		font-variant-numeric: tabular-nums;
	}

	.lock-icon {
		color: var(--fg-muted);
		opacity: 0.5;
	}

	.card-title {
		font-size: 1.125rem;
		color: var(--fg);
		letter-spacing: -0.01em;
		line-height: 1.3;
	}

	.card-summary {
		font-size: 0.9rem;
		color: var(--fg-muted);
		line-height: 1.6;
		margin: 0;
		flex: 1;
	}

	.card-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.stack-chip {
		padding: 0.2rem 0.5rem;
		background: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		font-size: 0.75rem;
		color: var(--fg-muted);
		font-family: ui-monospace, monospace;
	}

	.stack-chip.muted {
		color: var(--fg-muted);
		opacity: 0.6;
	}

	.card-arrow {
		font-size: 0.8125rem;
		color: var(--accent);
		font-weight: 600;
		margin-top: auto;
	}
</style>
