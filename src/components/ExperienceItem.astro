---
interface Props {
	company: string;
	role: string;
	start: string;
	end: string;
	location: string;
	tags: string[];
	isLast?: boolean;
}

const { company, role, start, end, location, tags, isLast = false } = Astro.props;

function formatDate(ym: string) {
	if (ym === 'present') return 'Present';
	const [year, month] = ym.split('-');
	const d = new Date(Number(year), Number(month) - 1);
	return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<div class:list={['exp-item', { 'is-last': isLast }]}>
	<div class="exp-timeline">
		<div class="timeline-dot"></div>
		{!isLast && <div class="timeline-line"></div>}
	</div>
	<div class="exp-content">
		<div class="exp-header">
			<div>
				<h3 class="exp-company">{company}</h3>
				<p class="exp-role">{role}</p>
			</div>
			<div class="exp-meta">
				<span class="exp-dates">{formatDate(start)} — {formatDate(end)}</span>
				<span class="exp-location">{location}</span>
			</div>
		</div>
		<div class="exp-body">
			<slot />
		</div>
		{tags.length > 0 && (
			<div class="exp-tags">
				{tags.map((tag) => (
					<span class="exp-tag">{tag}</span>
				))}
			</div>
		)}
	</div>
</div>

<style>
	.exp-item {
		display: grid;
		grid-template-columns: 2rem 1fr;
		gap: 0 1.25rem;
		padding-bottom: 3rem;
	}

	.exp-item.is-last {
		padding-bottom: 0;
	}

	.exp-timeline {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding-top: 0.375rem;
	}

	.timeline-dot {
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		background: var(--accent);
		border: 2px solid var(--bg);
		outline: 2px solid var(--accent);
		flex-shrink: 0;
	}

	.timeline-line {
		width: 1px;
		flex: 1;
		background: var(--border);
		margin-top: 0.5rem;
	}

	.exp-content {
		padding-bottom: 0.5rem;
	}

	.exp-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 0.75rem;
		flex-wrap: wrap;
	}

	.exp-company {
		font-size: 1.0625rem;
		font-weight: 700;
		color: var(--fg);
		letter-spacing: -0.01em;
		margin-bottom: 0.125rem;
	}

	.exp-role {
		font-size: 0.9375rem;
		color: var(--accent);
		font-weight: 600;
		margin: 0;
	}

	.exp-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.125rem;
		flex-shrink: 0;
	}

	.exp-dates {
		font-size: 0.8125rem;
		color: var(--fg-muted);
		white-space: nowrap;
		font-variant-numeric: tabular-nums;
	}

	.exp-location {
		font-size: 0.75rem;
		color: var(--fg-muted);
		opacity: 0.7;
	}

	.exp-body {
		color: var(--fg-muted);
		font-size: 0.9375rem;
		line-height: 1.7;
	}

	.exp-body :global(ul) {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.exp-body :global(ul li) {
		padding-left: 1.25rem;
		position: relative;
		margin-bottom: 0.375rem;
	}

	.exp-body :global(ul li::before) {
		content: "→";
		position: absolute;
		left: 0;
		color: var(--accent);
		font-size: 0.875rem;
	}

	.exp-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin-top: 0.875rem;
	}

	.exp-tag {
		padding: 0.2rem 0.5rem;
		background: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		font-size: 0.75rem;
		color: var(--fg-muted);
	}

	@media (max-width: 600px) {
		.exp-header {
			flex-direction: column;
		}
		.exp-meta {
			align-items: flex-start;
		}
	}
</style>
