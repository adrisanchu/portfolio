---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'projects'>['data'] & { slug: string };

const { title, summary, stack, tags, year, confidential, slug } = Astro.props;
---

<Layout title={title} description={summary}>
	<article class="project-article">
		<header class="project-header">
			<div class="project-meta">
				<a href="/projects" class="back-link">← All Projects</a>
				<span class="project-year">{year}</span>
			</div>
			<h1 class="project-title">{title}</h1>
			<p class="project-summary">{summary}</p>
			{confidential && (
				<div class="confidential-notice">
					<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
						<path d="M7 11V7a5 5 0 0 1 10 0v4"/>
					</svg>
					Confidential project — no source code or internal screenshots
				</div>
			)}
			<div class="project-stack">
				{stack.map((tech) => (
					<span class="stack-tag">{tech}</span>
				))}
			</div>
		</header>

		<div class="project-body prose">
			<slot />
		</div>

		<div class="project-tags">
			{tags.map((tag) => (
				<span class="tag">{tag}</span>
			))}
		</div>
	</article>
</Layout>

<style>
	.project-article {
		max-width: 48rem;
		margin: 0 auto;
		padding: 3rem 1.5rem 5rem;
	}

	.project-header {
		margin-bottom: 3rem;
	}

	.project-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5rem;
	}

	.back-link {
		font-size: 0.875rem;
		color: var(--fg-muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.back-link:hover {
		color: var(--accent);
	}

	.project-year {
		font-size: 0.875rem;
		color: var(--fg-muted);
		font-variant-numeric: tabular-nums;
	}

	.project-title {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		margin-bottom: 1rem;
		color: var(--fg);
		letter-spacing: -0.02em;
	}

	.project-summary {
		font-size: 1.125rem;
		color: var(--fg-muted);
		margin-bottom: 1.25rem;
		line-height: 1.6;
	}

	.confidential-notice {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.375rem 0.75rem;
		background: rgba(245, 158, 11, 0.1);
		border: 1px solid rgba(245, 158, 11, 0.2);
		border-radius: 6px;
		font-size: 0.8125rem;
		color: var(--accent);
		margin-bottom: 1.25rem;
	}

	.project-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	.stack-tag {
		padding: 0.25rem 0.625rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 4px;
		font-size: 0.8125rem;
		color: var(--fg-muted);
		font-family: ui-monospace, monospace;
	}

	.project-body {
		border-top: 1px solid var(--border);
		padding-top: 2rem;
	}

	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.tag {
		padding: 0.25rem 0.625rem;
		background: var(--accent-muted);
		color: var(--accent);
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.025em;
	}
</style>
