---
import Layout from '../layouts/Layout.astro';
import { LINKEDIN_URL, GITHUB_URL, EMAIL } from '../consts';
---

<Layout
	title="Contact"
	description="Get in touch — open to collaborate on consulting projects and interesting problems at the intersection of software and critical infrastructure."
>
	<div class="contact-page">
		<header class="page-header">
			<p class="page-label">Contact</p>
			<h1 class="page-title">Let's talk.</h1>
			<p class="page-intro">
				Open to collaborate on consulting projects and interesting problems at the intersection
				of software, data, and critical infrastructure.
			</p>
		</header>

		<div class="contact-grid">
			<a href={`mailto:${EMAIL}`} class="contact-card primary">
				<div class="contact-icon">
					<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect width="20" height="16" x="2" y="4" rx="2"/>
						<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
					</svg>
				</div>
				<div class="contact-text">
					<span class="contact-label">Email</span>
					<span class="contact-value">{EMAIL}</span>
				</div>
				<span class="contact-arrow">→</span>
			</a>

			<a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="contact-card">
				<div class="contact-icon">
					<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
					</svg>
				</div>
				<div class="contact-text">
					<span class="contact-label">LinkedIn</span>
					<span class="contact-value">linkedin.com/in/adriansanchezr</span>
				</div>
				<span class="contact-arrow">↗</span>
			</a>

			<a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="contact-card">
				<div class="contact-icon">
					<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
						<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
					</svg>
				</div>
				<div class="contact-text">
					<span class="contact-label">GitHub</span>
					<span class="contact-value">github.com/adrisanchu</span>
				</div>
				<span class="contact-arrow">↗</span>
			</a>
		</div>
	</div>
</Layout>

<style>
	.contact-page {
		max-width: 40rem;
		margin: 0 auto;
		padding: 3rem 1.5rem 5rem;
	}

	.page-header {
		margin-bottom: 3rem;
	}

	.page-label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		margin-bottom: 0.75rem;
	}

	.page-title {
		font-size: clamp(2.5rem, 7vw, 4rem);
		letter-spacing: -0.03em;
		color: var(--fg);
		margin-bottom: 1rem;
	}

	.page-intro {
		font-size: 1.0625rem;
		color: var(--fg-muted);
		line-height: 1.7;
		margin: 0;
	}

	.contact-grid {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
	}

	.contact-card {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		padding: 1.25rem 1.5rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.15s ease, transform 0.15s ease;
	}

	.contact-card:hover {
		border-color: var(--accent);
		transform: translateX(4px);
	}

	.contact-card.primary {
		border-color: rgba(245, 158, 11, 0.3);
	}

	.contact-icon {
		width: 2.75rem;
		height: 2.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: 10px;
		color: var(--accent);
		flex-shrink: 0;
	}

	.location-icon {
		color: var(--fg-muted);
	}

	.contact-text {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
		flex: 1;
	}

	.contact-label {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--fg-muted);
		font-weight: 600;
	}

	.contact-value {
		font-size: 0.9375rem;
		color: var(--fg);
		font-weight: 600;
	}

	.contact-languages {
		font-size: 0.8125rem;
		color: var(--fg-muted);
		margin-top: 0.25rem;
	}

	.contact-arrow {
		font-size: 1.125rem;
		color: var(--accent);
		flex-shrink: 0;
	}
</style>
