---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('education'))
	.sort((a, b) => a.data.order - b.data.order);

const renderedEntries = await Promise.all(
	entries.map(async (entry) => {
		const { Content } = await render(entry);
		return { entry, Content };
	})
);

const certifications = [
	{ title: "Project Management Professional (PMP)", org: "PMI", year: "2025", note: "In preparation" },
	{ title: "Data Scientist Professional", org: "Red Eléctrica", year: "2025", note: "90h programme" },
	{ title: "Business Analyst Certificate", org: "Red Eléctrica", year: "2023", note: "130h programme" },
	{ title: "The Web Developer Bootcamp", org: "Udemy", year: "2021", note: "63h" },
];

const awards = [
	{
		title: "Sciences & Enseignement Fellowship",
		org: "EDF Foundation & Institut de France",
		year: "2016",
		desc: "MSc fully funded on academic merit. Competitive fellowship awarded by the EDF Foundation and Institut de France to outstanding engineering students.",
	},
	{
		title: "Research Award — Best Sustainable Energy Project",
		org: "École Polytechnique",
		year: "2016",
		desc: "Awarded for the MSc research thesis on sustainable energy systems. Thesis received a score of 20/20 with distinction.",
	},
	{
		title: "2nd Place — #ReactivaMadrid Hackathon",
		org: "Madrid City Hall",
		year: "2020",
		desc: "Crowd flow modelling tool for safely reopening public spaces during COVID-19.",
	},
];
---

<Layout
	title="Education"
	description="Academic background — Industrial Engineering at UPM, international exchange at École Polytechnique, MSc Nuclear Energy at Paris-Saclay."
>
	<div class="education-page">
		<header class="page-header">
			<p class="page-label">Education</p>
			<h1 class="page-title">Academic Background</h1>
		</header>

		<!-- Degrees -->
		<section class="edu-section">
			<div class="edu-cards">
				{renderedEntries.map(({ entry, Content }) => (
					<div class="edu-card">
						<div class="edu-card-header">
							<div>
								<h2 class="edu-institution">{entry.data.institution}</h2>
								<p class="edu-degree">{entry.data.degree}</p>
							</div>
							<div class="edu-meta">
								<span class="edu-period">{entry.data.period}</span>
								<span class="edu-location">{entry.data.location}</span>
							</div>
						</div>
						{entry.data.details && (
							<div class="edu-highlights">
								{entry.data.details.split(' · ').map((detail: string) => (
									<span class="highlight-chip">{detail}</span>
								))}
							</div>
						)}
						<div class="edu-body">
							<Content />
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Certifications -->
		<section class="edu-section">
			<h2 class="section-title">Certifications</h2>
			<div class="cert-list">
				{certifications.map(cert => (
					<div class="cert-item">
						<div class="cert-main">
							<span class="cert-title">{cert.title}</span>
							<span class="cert-org">{cert.org}</span>
						</div>
						<div class="cert-right">
							{cert.note && <span class="cert-note">{cert.note}</span>}
							<span class="cert-year">{cert.year}</span>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Awards -->
		<section class="edu-section">
			<h2 class="section-title">Awards & Recognition</h2>
			<div class="awards-list">
				{awards.map(award => (
					<div class="award-item">
						<div class="award-header">
							<h3 class="award-title">{award.title}</h3>
							<span class="award-year">{award.year}</span>
						</div>
						<p class="award-org">{award.org}</p>
						<p class="award-desc">{award.desc}</p>
					</div>
				))}
			</div>
		</section>
	</div>
</Layout>

<style>
	.education-page {
		max-width: 52rem;
		margin: 0 auto;
		padding: 3rem 1.5rem 5rem;
	}

	.page-header {
		margin-bottom: 3rem;
	}

	.page-label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		margin-bottom: 0.75rem;
	}

	.page-title {
		font-size: clamp(2rem, 5vw, 3rem);
		letter-spacing: -0.03em;
		color: var(--fg);
		margin: 0;
	}

	/* ─── Degrees ─── */
	.edu-section {
		margin-bottom: 3.5rem;
		padding-bottom: 3.5rem;
		border-bottom: 1px solid var(--border);
	}

	.edu-section:last-child {
		border-bottom: none;
		margin-bottom: 0;
		padding-bottom: 0;
	}

	.edu-cards {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.edu-card {
		padding: 1.5rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
	}

	.edu-card-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 0.875rem;
		flex-wrap: wrap;
	}

	.edu-institution {
		font-size: 1.0625rem;
		font-weight: 700;
		color: var(--fg);
		margin-bottom: 0.25rem;
		letter-spacing: -0.01em;
	}

	.edu-degree {
		font-size: 0.9375rem;
		color: var(--accent);
		font-weight: 600;
		margin: 0;
	}

	.edu-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.125rem;
		flex-shrink: 0;
	}

	.edu-period {
		font-size: 0.875rem;
		color: var(--fg-muted);
		font-variant-numeric: tabular-nums;
	}

	.edu-location {
		font-size: 0.8125rem;
		color: var(--fg-muted);
		opacity: 0.7;
	}

	.edu-highlights {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin-bottom: 1rem;
	}

	.highlight-chip {
		padding: 0.2rem 0.625rem;
		background: rgba(245, 158, 11, 0.1);
		border: 1px solid rgba(245, 158, 11, 0.2);
		border-radius: 4px;
		font-size: 0.8rem;
		color: var(--accent);
	}

	.edu-body {
		font-size: 0.9375rem;
		color: var(--fg-muted);
		line-height: 1.7;
	}

	.edu-body :global(p) {
		margin: 0;
	}

	/* ─── Certifications ─── */
	.section-title {
		font-size: 1rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--fg-muted);
		margin-bottom: 1.25rem;
	}

	.cert-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.cert-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.875rem 1.25rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 8px;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.cert-main {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.cert-title {
		font-size: 0.9375rem;
		color: var(--fg);
		font-weight: 600;
	}

	.cert-org {
		font-size: 0.8125rem;
		color: var(--fg-muted);
	}

	.cert-right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.125rem;
		flex-shrink: 0;
	}

	.cert-note {
		font-size: 0.75rem;
		color: var(--fg-muted);
		opacity: 0.7;
	}

	.cert-year {
		font-size: 0.875rem;
		color: var(--fg-muted);
		font-variant-numeric: tabular-nums;
	}

	/* ─── Awards ─── */
	.awards-list {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.award-item {
		padding: 1.25rem 1.5rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 0 8px 8px 0;
	}

	.award-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.5rem;
		margin-bottom: 0.25rem;
	}

	.award-title {
		font-size: 0.9375rem;
		font-weight: 700;
		color: var(--fg);
	}

	.award-year {
		font-size: 0.8125rem;
		color: var(--fg-muted);
		flex-shrink: 0;
		font-variant-numeric: tabular-nums;
	}

	.award-org {
		font-size: 0.8125rem;
		color: var(--accent);
		margin: 0 0 0.5rem;
		font-weight: 600;
	}

	.award-desc {
		font-size: 0.875rem;
		color: var(--fg-muted);
		margin: 0;
		line-height: 1.6;
	}

	@media (max-width: 520px) {
		.edu-card-header,
		.cert-item {
			flex-direction: column;
		}
		.edu-meta,
		.cert-right {
			align-items: flex-start;
		}
	}
</style>
