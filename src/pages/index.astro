---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { LINKEDIN_URL, EMAIL } from '../consts';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
	.filter(p => p.data.featured)
	.sort((a, b) => b.data.year - a.data.year)
	.slice(0, 3);

const skills = [
	{ label: 'Software Dev', items: ['Python', 'TypeScript', 'SvelteKit', 'FastAPI', 'Node.js'] },
	{ label: 'Data & BI', items: ['SQL', 'DuckDB', 'Power BI', 'Data Modelling'] },
	{ label: 'Cloud', items: ['AWS', 'Docker', 'Cloudflare', 'PostgreSQL'] },
	{ label: 'Engineering', items: ['Project Management', 'PMO', 'Energy Systems', 'Nuclear'] },
];
---

<Layout isHomepage={true}>
	<!-- ─── Hero ─────────────────────────────────────────────── -->
	<section class="hero">
		<div class="hero-inner">
			<h1 class="hero-name animate-in delay-2">
				Adrián Sánchez<br/><span class="accent">Rodríguez</span>
			</h1>
			<p class="hero-tagline animate-in delay-3">
				Engineer by training. Developer by choice.<br class="br-lg"/>
				I build software that runs critical infrastructure.
			</p>
			<div class="hero-ctas animate-in delay-4">
				<a href="/projects" class="btn-primary">View Projects</a>
				<a href="/cv.pdf" download class="btn-ghost">Download CV ↓</a>
			</div>
			<p class="hero-interests animate-in delay-5">
				Software engineering · Energy systems · Project governance
			</p>
			<hr class="hero-rule animate-in delay-5 fade-only" aria-hidden="true" />
		</div>
	</section>

	<!-- ─── Selected Projects ─────────────────────────────────── -->
	<section class="section">
		<div class="section-inner">
			<div class="section-header reveal">
				<h2 class="section-title">Selected Projects</h2>
				<a href="/projects" class="section-link">All projects →</a>
			</div>
			<div class="projects-grid">
				{featuredProjects.map((project, i) => (
					<div class:list={['reveal', i === 1 && 'reveal-delay']}>
						<ProjectCard
							slug={project.id}
							title={project.data.title}
							summary={project.data.summary}
							stack={project.data.stack}
							year={project.data.year}
							featured={project.data.featured}
							confidential={project.data.confidential}
						/>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── About Teaser ──────────────────────────────────────── -->
	<section class="section section-alt">
		<div class="section-inner about-teaser">
			<div class="about-text reveal">
				<h2 class="section-title">Unusual career.<br/>Intentional journey.</h2>
				<p>
					Nuclear engineering in France, grid infrastructure at Spain's national TSO, and a
					self-taught software arc that evolved into a formal engineering role. Each chapter builds
					on the last.
				</p>
				<p>
					I work at the intersection of energy systems and software — a combination rare enough to be
					genuinely useful, and interesting enough to keep me engaged.
				</p>
				<a href="/about" class="btn-ghost">Read the full story →</a>
			</div>
			<div class="career-arc reveal">
				<div class="arc-track">
					<svg class="arc-connector" viewBox="0 0 406 140" preserveAspectRatio="none" aria-hidden="true">
						<defs>
							<marker id="arc-tip" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
								<path d="M 0 0 L 8 4 L 0 8 z" class="arc-arrowhead"/>
							</marker>
						</defs>
						<path class="arc-path" d="M -15 71 C 5 87, 14 115, 65 115 C 116 115, 152 45, 203 45 C 254 45, 290 115, 341 115 C 392 115, 401 86, 421 71" marker-end="url(#arc-tip)"/>
					</svg>
					<div class="arc-step">
						<span class="arc-icon">⚛</span>
						<span class="arc-label">Nuclear Engineering<br/><small>2016–2017</small></span>
					</div>
					<div class="arc-step">
						<span class="arc-icon">⚡</span>
						<span class="arc-label">Energy Grid<br/><small>2019–2023</small></span>
					</div>
					<div class="arc-step">
						<span class="arc-icon">{'</>'}</span>
						<span class="arc-label">Software Architect<br/><small>2024–present</small></span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── Skills Snapshot ───────────────────────────────────── -->
	<section class="section">
		<div class="section-inner">
			<div class="section-header reveal">
				<h2 class="section-title">Skills Snapshot</h2>
				<a href="/skills" class="section-link">Full taxonomy →</a>
			</div>
			<div class="skills-grid">
				{skills.map(group => (
					<div class="skill-group reveal">
						<h3 class="skill-group-label">{group.label}</h3>
						<div class="skill-chips">
							{group.items.map(item => (
								<span class="skill-chip">{item}</span>
							))}
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── Contact CTA ───────────────────────────────────────── -->
	<section class="section section-cta">
		<div class="section-inner cta-inner">
			<h2 class="cta-title reveal">Let's talk.</h2>
			<p class="cta-sub reveal">Open to collaborate on consulting projects, research, and interesting problems at the intersection of software and critical infrastructure.</p>
			<div class="cta-links reveal">
				<a href={`mailto:${EMAIL}`} class="btn-primary">Send an email</a>
				<a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="btn-ghost">LinkedIn →</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* ─── Hero ─── */
	.hero {
		padding: 5rem 1.5rem 3rem;
		max-width: 72rem;
		margin: 0 auto;
		position: relative;
	}

	/* Subtle radial glow behind the hero */
	.hero::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 60% 50% at 20% 40%, rgba(245, 158, 11, 0.06) 0%, transparent 70%);
		pointer-events: none;
	}

	.hero-inner {
		max-width: 48rem;
		position: relative;
	}

	.hero-label {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.8125rem;
		color: var(--fg-muted);
		margin-bottom: 1.75rem;
		padding: 0.375rem 0.75rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		letter-spacing: 0.02em;
	}

	.dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: #22c55e;
		box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.25);
		animation: pulse 2.5s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.25); }
		50% { box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.1); }
	}

	.hero-name {
		font-size: clamp(2.75rem, 8vw, 5.5rem);
		letter-spacing: -0.03em;
		line-height: 1.0;
		margin-bottom: 1.5rem;
		color: var(--fg);
	}

	.accent {
		color: var(--accent);
	}

	.hero-tagline {
		font-size: clamp(1rem, 2.5vw, 1.25rem);
		color: var(--fg-muted);
		line-height: 1.65;
		margin-bottom: 2.25rem;
	}

	.br-lg {
		display: none;
	}
	@media (min-width: 640px) {
		.br-lg { display: block; }
	}

	.hero-ctas {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-bottom: 1.75rem;
	}

	.hero-interests {
		font-size: 0.8125rem;
		color: var(--fg-muted);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		margin-bottom: 3rem;
	}

	.hero-rule {
		border: none;
		border-top: 1px solid var(--accent);
		opacity: 0.4;
		width: 3rem;
		margin: 0;
	}

	/* ─── Buttons ─── */
	.btn-primary {
		display: inline-flex;
		align-items: center;
		padding: 0.625rem 1.375rem;
		background: var(--accent);
		color: var(--btn-primary-text);
		font-weight: 700;
		font-size: 0.9375rem;
		border-radius: 8px;
		text-decoration: none;
		transition: background 0.15s ease, transform 0.15s ease, color 0.15s ease;
	}

	.btn-primary:hover {
		background: var(--accent-hover);
		color: var(--btn-primary-text);
		transform: translateY(-1px);
	}

	.btn-ghost {
		display: inline-flex;
		align-items: center;
		padding: 0.625rem 1.375rem;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		font-weight: 600;
		font-size: 0.9375rem;
		border-radius: 8px;
		text-decoration: none;
		transition: border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
	}

	.btn-ghost:hover {
		border-color: var(--accent);
		color: var(--accent);
		transform: translateY(-1px);
	}

	/* ─── Sections ─── */
	.section {
		padding: 3rem 1.5rem;
	}

	.section-alt {
		background: var(--bg-surface);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}

	.section-inner {
		max-width: 72rem;
		margin: 0 auto;
	}

	.section-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 2.5rem;
		gap: 1rem;
	}

	.section-title {
		font-size: clamp(1.375rem, 3vw, 1.875rem);
		letter-spacing: -0.025em;
		color: var(--fg);
	}

	.section-link {
		font-size: 0.875rem;
		color: var(--accent);
		white-space: nowrap;
	}

	/* ─── Projects Grid ─── */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
		gap: 1.25rem;
	}

	.projects-grid > div {
		display: contents;
	}

	.reveal-delay {
		animation-delay: 0.1s;
	}

	/* ─── About Teaser ─── */
	.about-teaser {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: center;
	}

	@media (min-width: 1024px) {
		.about-teaser {
			grid-template-columns: 1fr 1fr;
		}
	}

	.about-text p {
		color: var(--fg-muted);
		margin-bottom: 1rem;
	}

	.about-text .section-title {
		margin-bottom: 1.25rem;
	}

	.career-arc {
		overflow-x: auto;
		scrollbar-width: none;
		display: flex;
		justify-content: center;
	}

	.career-arc::-webkit-scrollbar {
		display: none;
	}

	.arc-track {
		position: relative;
		width: 406px;
		height: 160px;
		flex-shrink: 0;
	}

	.arc-connector {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
		overflow: visible;
	}

	.arc-path {
		stroke: var(--accent);
		stroke-width: 2.5;
		stroke-dasharray: 6 4;
		stroke-opacity: 1;
		fill: none;
	}

	.arc-arrowhead {
		fill: var(--accent);
		opacity: 1;
	}

	.arc-step {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		padding: 0.5rem 0.75rem;
		background: color-mix(in srgb, var(--bg-card) 55%, transparent);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
		border-radius: 10px;
		transition: border-color 0.2s ease;
		position: absolute;
		width: 130px;
		z-index: 1;
	}

	.arc-step:nth-child(2) {
		top: 12px;
		left: 0;
	}

	.arc-step:nth-child(3) {
		bottom: 12px;
		left: 138px;
	}

	.arc-step:nth-child(4) {
		top: 12px;
		left: 276px;
	}

	.arc-step:hover {
		border-color: rgba(245, 158, 11, 0.4);
	}

	.arc-icon {
		font-size: 1.25rem;
		line-height: 1;
	}

	.arc-label {
		font-size: 0.8125rem;
		color: var(--fg);
		font-weight: 600;
		line-height: 1.4;
	}

	.arc-label small {
		color: var(--fg-muted);
		font-weight: 400;
	}

	@media (max-width: 560px) {
		.arc-track {
			width: 300px;
			height: 150px;
		}

		.arc-step:nth-child(2) {
			left: 0px;
			width: 100px;
		}

		.arc-step:nth-child(3) {
			left: 100px;
			width: 100px;
		}

		.arc-step:nth-child(4) {
			left: 200px;
			width: 100px;
		}

		.arc-icon {
			display: none;
		}
	}

	/* ─── Skills Snapshot ─── */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
		gap: 1.25rem;
	}

	.skill-group {
		padding: 1.25rem 1.375rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 10px;
		transition: border-color 0.2s ease;
	}

	.skill-group:hover {
		border-color: rgba(245, 158, 11, 0.3);
	}

	.skill-group-label {
		font-size: 0.6875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		margin-bottom: 0.875rem;
	}

	.skill-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.skill-chip {
		padding: 0.25rem 0.5625rem;
		background: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		font-size: 0.8125rem;
		color: var(--fg-muted);
	}

	/* ─── CTA ─── */
	.section-cta {
		background: linear-gradient(135deg, rgba(245, 158, 11, 0.05) 0%, transparent 60%);
		border-top: 1px solid rgba(245, 158, 11, 0.12);
	}

	.cta-inner {
		text-align: center;
		max-width: 36rem;
		padding: 2rem 1.5rem;
	}

	.cta-title {
		font-size: clamp(2.25rem, 5vw, 3.5rem);
		letter-spacing: -0.035em;
		color: var(--fg);
		margin-bottom: 0.875rem;
		font-family: var(--font-display);
		font-weight: normal;
	}

	.cta-sub {
		color: var(--fg-muted);
		font-size: 1rem;
		margin-bottom: 2rem;
		line-height: 1.65;
	}

	.cta-links {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		flex-wrap: wrap;
	}
</style>
